# Provider credentials
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=your_openai_compatible_api_key

# Azure OpenAI (alternate frontier-model provider)
# Set --provider azure on the CLI; pass deployment name as --model.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_AGENT=
AZURE_OPENAI_DEPLOYMENT_USER=
AZURE_OPENAI_DEPLOYMENT_RERANKER=

# Cascade reranker provider — controls which provider the stage-3 LLM rerank
# in cascade_retriever uses. Defaults to openrouter (claude-haiku-4.5).
KAIROS_RERANKER_PROVIDER=openrouter

# Base URLs
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1

# Phoenix / OTLP
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces

# Required benchmark defaults
TAU_BENCH_PROVIDER=openrouter
TAU_BENCH_MODEL=moonshotai/kimi-k2
TAU_BENCH_USER_MODEL=
TAU_BENCH_ENABLE_NVIDIA=0

# Agent and user strategies
TAU_BENCH_AGENT_STRATEGY=tool-calling
TAU_BENCH_USER_STRATEGY=llm

# Agent request tuning
TAU_BENCH_TOP_P=0.95
TAU_BENCH_MAX_TOKENS=16384
TAU_BENCH_TIMEOUT=120
TAU_BENCH_THINKING=0
TAU_BENCH_REASONING_EFFORT=
TAU_BENCH_RETRIES=0

# User simulator request tuning
TAU_BENCH_USER_TOP_P=0.95
TAU_BENCH_USER_MAX_TOKENS=128
TAU_BENCH_USER_TIMEOUT=300
TAU_BENCH_USER_THINKING=0
TAU_BENCH_USER_REASONING_EFFORT=
TAU_BENCH_USER_RETRIES=2

# Concurrency and request pacing
TAU_BENCH_MAX_CONCURRENCY=1
TAU_BENCH_SLEEP_BETWEEN_TASKS=0
TAU_BENCH_REQUESTS_PER_MINUTE=12

# Rate-limit backoff
TAU_BENCH_RATE_LIMIT_RETRIES=6
TAU_BENCH_RATE_LIMIT_BACKOFF_BASE=5
TAU_BENCH_RATE_LIMIT_BACKOFF_MAX=60
TAU_BENCH_RATE_LIMIT_BACKOFF_JITTER=1
TAU_BENCH_SDK_MAX_RETRIES=0
TAU_BENCH_LOG_API_HEADERS=1

# NVIDIA -> OpenRouter fallback
TAU_BENCH_OPENROUTER_FALLBACK=1
TAU_BENCH_OPENROUTER_FALLBACK_MODEL=
TAU_BENCH_NVIDIA_RATE_LIMIT_RETRIES_BEFORE_FALLBACK=3

# Output paths
TAU_BENCH_RESULTS_DIR=results
TAU_BENCH_ENABLE_KAIROS=0
KAIROS_TAU_INJECT_PLAN=0
TAU_BENCH_KAIROS_RAW_DIR=data/live/raw
TAU_BENCH_KAIROS_NORMALIZED_DIR=data/live/normalized

# Kairos semantic recovery
KAIROS_SEMANTIC_EXPECTATION_ENABLED=false
KAIROS_SEMANTIC_PROVIDER=openrouter
KAIROS_SEMANTIC_MODEL=microsoft/phi-4-mini-instruct
KAIROS_SEMANTIC_TEMPERATURE=0
KAIROS_SEMANTIC_TIMEOUT_S=60
KAIROS_SEMANTIC_OPENROUTER_API_KEY=
KAIROS_SEMANTIC_TOOL_POLICY_AUDITOR_ENABLED=false
KAIROS_SEMANTIC_TOOL_POLICY_AUDITOR_BLOCKING=false
KAIROS_WORKFLOW_MEMORY_PATHS=
